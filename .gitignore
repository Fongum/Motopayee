# =========================
# MotoPayee (Next.js) .gitignore
# =========================

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage / test output
coverage
*.lcov
.nyc_output

# Build outputs
.next/
out/
build/
dist/
.nuxt/
.svelte-kit/
**/.vitepress/dist
**/.vitepress/cache
.vuepress/dist
.serverless/
.docusaurus/
.fusebox/
.dynamodb/

# Dependencies
node_modules/
jspm_packages/
web_modules/
.pnp
.pnp.js
.pnp.*
.yarn/install-state.gz

# TypeScript
*.tsbuildinfo

# ESLint / Stylelint caches
.eslintcache
.stylelintcache

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor folders
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp

# Environment variables (IMPORTANT: never commit secrets)
.env
.env.*
!.env.example
.env.local
.env.*.local

# Vercel
.vercel/

# Supabase (if you use Supabase CLI locally)
.supabase/

# Certificates / keys
*.pem

# Optional npm cache
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# Yarn v3 (keep the folder but ignore most files)
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Vite timestamp logs (harmless even if not used)
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
.vercel
